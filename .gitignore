# LaTeX build artifacts
/build/
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.synctex.gz
*.toc
*.idx
*.ind
*.ilg
*.nav
*.snm
*.vrb
*.run.xml
*.bcf
*.pdf

# Keep build dir tracked but empty
!/build/.gitkeep

# Keep committed figure PDFs (generated from figures/tex or figures/data)
!figures/pdf/
!figures/pdf/*.pdf
# but not the preview rasters
figures/pdf/*.png
# except the cover PNG, which the EPUB build embeds as --epub-cover-image
!figures/pdf/cover.png

# Track the built monograph (PDF + EPUB) so both are downloadable from the repo.
# No git-lfs here; a few MB is fine and consistent with committing the figure PDFs
# above. Rebuilt by `make` / `make epub`; refresh before committing.
!/book.pdf
!/book.epub

# Python / sims
__pycache__/
*.pyc
.venv/
venv/
sims/**/output/

# Python build/editable-install artifacts
*.egg-info/
*.egg-link

# standalone paper build artifacts (the .tex is the source of truth);
# the built PDF IS tracked (like book.pdf) so it is reviewable/downloadable from the repo
# (negating the global *.pdf rule above, as book.pdf and the figure PDFs do).
!papers/*.pdf
papers/*.blg
papers/*.out
papers/*.synctex.gz
