# LaTeX build artifacts
build/
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.synctex.gz
*.toc
*.idx
*.ind
*.ilg
*.nav
*.snm
*.vrb
*.run.xml
*.bcf
*.pdf

# Keep build dir tracked but empty
!build/.gitkeep

# Keep committed figure PDFs (generated from figures/tex or figures/data)
!figures/pdf/
!figures/pdf/*.pdf
# but not the preview rasters
figures/pdf/*.png

# Track the built monograph (PDF + EPUB) so both are downloadable from the repo.
# No git-lfs here; a few MB is fine and consistent with committing the figure PDFs
# above. Rebuilt by `make` / `make epub`; refresh before committing.
!/book.pdf
!/book.epub

# Python / sims
__pycache__/
*.pyc
.venv/
venv/
sims/**/output/

# Python build/editable-install artifacts
*.egg-info/
*.egg-link
