# LaTeX build artifacts
build/
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.synctex.gz
*.toc
*.idx
*.ind
*.ilg
*.nav
*.snm
*.vrb
*.run.xml
*.bcf
*.pdf

# Keep build dir tracked but empty
!build/.gitkeep

# Keep committed figure PDFs (generated from figures/tex or figures/data)
!figures/pdf/
!figures/pdf/*.pdf
# but not the preview rasters
figures/pdf/*.png

# Track the built monograph so it is downloadable from the repo. No git-lfs is
# available here; ~1 MB is fine for git and is consistent with committing the
# figure PDFs above. Rebuilt by `make`; refresh before committing.
!/book.pdf

# Python / sims
__pycache__/
*.pyc
.venv/
venv/
sims/**/output/

# Python build/editable-install artifacts
*.egg-info/
*.egg-link
