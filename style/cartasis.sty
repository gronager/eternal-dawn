% cartasis.sty — style package for the Eternal Dawn monograph.
% Designed for the `memoir` class. Palatino (mathpazo) text + math, a classic
% Bringhurst chapter style, generous outer margin for sidenotes and margin
% citations.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/cartasis}[2026/05/30 Supraverse Cartasis Theory style]

% --- Encoding and fonts (Palatino) ---
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{mathpazo}            % Palatino text + matching math
\RequirePackage[scaled=0.88]{helvet} % Helvetica for sans (heads), scaled to match
\RequirePackage{microtype}
\linespread{1.05}                    % Palatino wants a little extra leading

% --- Math ---
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{amsthm}
\RequirePackage{mathtools}

% --- Tables, graphics, lists ---
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{graphicx}
\graphicspath{{figures/pdf/}}
\RequirePackage{eso-pic}   % full-bleed background images (the front cover)
\RequirePackage{enumitem}
\setlist{itemsep=0.2ex, topsep=0.6ex}

% --- Page layout (memoir) ---
% Generous outer margin holds sidenotes and margin citations.
\setlrmarginsandblock{1.1in}{2.1in}{*}
\setulmarginsandblock{1.2in}{1.4in}{*}
\setmarginnotes{0.25in}{1.7in}{\onelineskip}
\setheadfoot{\onelineskip}{2\onelineskip}
\setheaderspaces{*}{2\onelineskip}{*}
\checkandfixthelayout

% --- Sectioning, headers, ToC ---
% Custom chapter style: shows the chapter NUMBER prominently above the title,
% in the sans/small-caps idiom of the rest of the headings (bringhurst hid it).
\makechapterstyle{cartasischap}{%
  \setlength{\beforechapskip}{2\onelineskip}%
  \setlength{\afterchapskip}{2\onelineskip}%
  \renewcommand*{\chapnamefont}{\normalfont\sffamily\bfseries\small}%
  \renewcommand*{\chapnumfont}{\normalfont\sffamily\bfseries\Huge}%
  \renewcommand*{\chaptitlefont}{\normalfont\sffamily\bfseries\LARGE}%
  \renewcommand*{\printchaptername}{%
    \chapnamefont\MakeUppercase{\@chapapp}}%
  \renewcommand*{\chapternamenum}{\space}%
  \renewcommand*{\printchapternum}{\chapnumfont\thechapter}%
  \renewcommand*{\afterchapternum}{\par\nobreak\vskip\onelineskip}%
  \renewcommand*{\printchaptertitle}[1]{\chaptitlefont ##1\par\nobreak
    \vskip\onelineskip \hrule height \normalrulethickness}%
}
\chapterstyle{cartasischap}
\setsecnumdepth{subsection}
\maxsecnumdepth{subsection}
\settocdepth{section}
\makepagestyle{cartasis}
\makeevenhead{cartasis}{\thepage}{}{\scshape\small\leftmark}
\makeoddhead{cartasis}{\scshape\small\rightmark}{}{\thepage}
\makeheadrule{cartasis}{\textwidth}{\normalrulethickness}
\pagestyle{cartasis}
% Sans, small-caps style for section heads in the Palatino setting
\setsecheadstyle{\normalfont\sffamily\bfseries\large}
\setsubsecheadstyle{\normalfont\sffamily\bfseries\normalsize}
\setsubsubsecheadstyle{\normalfont\sffamily\itshape\normalsize}

% --- Citations and cross-references (natbib; hyperref before cleveref) ---
\RequirePackage[numbers,sort&compress]{natbib}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage{cleveref}

% --- Theorem-like environments for the framework's claims ---
\theoremstyle{definition}
\newtheorem{axiom}{Axiom}
\renewcommand{\theaxiom}{A\arabic{axiom}}   % A1, A2, ...
\theoremstyle{remark}
\newtheorem{conjecture}{Conjecture}
\newtheorem*{openquestion}{Open question}

% --- Convenience macros ---
\RequirePackage{xspace}
\newcommand{\rhoc}{\rho_{C}}                  % Cartasis density
\newcommand{\Msun}{M_{\odot}}
\newcommand{\SCT}{\textsc{sct}\xspace}
\newcommand{\Cartasis}{\emph{Cartasis}\xspace}
% A lightweight sidenote for epistemic asides / margin remarks.
\newcommand{\sidenote}[1]{\marginpar{\footnotesize\raggedright #1}}

% Last-resort stretch so long inline math / monospace paths don't overrun the margin.
\setlength{\emergencystretch}{3em}

\endinput
